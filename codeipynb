    "# author: Zeba\n",
    "# Union-Find data structure for merging cluster labels in Stage 4\n",
    "\n",
    "#how it works:\n",
    "#each cluster starts as its own \"parent\"\n",
    "#when two clusters need to merge, we union them — one becomes the child of the other\n",
    "#find() follows the chain up to the root (canonical label)\n",
    "#path compression makes repeated finds very fast\n",
    "\n",
    "class UnionFind:\n",
    "    def __init__(self):\n",
    "        self.parent = {}\n",
    "\n",
    "    def find(self, x):\n",
    "        #path compression — flattens the chain for future lookups\n",
    "        self.parent.setdefault(x, x)\n",
    "        if self.parent[x] != x:\n",
    "            self.parent[x] = self.find(self.parent[x])\n",
    "        return self.parent[x]\n",
    "\n",
    "    def union(self, x, y):\n",
    "        #merge two clusters — one root becomes child of the other\n",
    "        rx, ry = self.find(x), self.find(y)\n",
    "        if rx != ry:\n",
    "            self.parent[ry] = rx\n",
    "\n",
    "print(\"UnionFind class defined.\")"
   ]
