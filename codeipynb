    "#author: Javeria\n",
    "# Local Approach Step 1 \n",
    "#Step 1: add epsilon-buffer points to each partition \n",
    "\n",
    "def get_neighbour_cell_ids(grid_row, grid_col, n_cols, n_rows): \n",
    "  \"\"\"return only existing neighbours (not out of bounds)\"\"\"\n",
    "  neighbours = []\n",
    "  for dr in [-1,0,1]:\n",
    "    for dc in [-1,0,1]: \n",
    "      if dr == 0 and dc == 0: \n",
    "        continue \n",
    "      r, c = grid_row + dr, grid_col + dc\n",
    "      if 0 <= r < n_rows and 0 <= c < n_cols: \n",
    "        neighbours.append(r*n_cols +c)\n",
    "  return neighbours\n",
    "  #O(n) per point\n",
    "\n",
    "#compute grid dimensions\n",
    "N_ROWS = math.ceil((LAT_MAX - LAT_MIN) / CELL_SIZE)\n",
    "N_COLS = math.ceil((LON_MAX - LON_MIN) / CELL_SIZE)\n",
    "\n",
    "#UDF: given a cell_id, return a list of neighbour cell_ids\n",
    "@F.udf(returnType=ArrayType(IntegerType()))\n",
    "def neighbour_cells_udf(grid_row, grid_col): \n",
    "  return get_neighbour_cell_ids(grid_row, grid_col, N_COLS, N_ROWS)\n",
    "\n",
    "#for each point, emit a copy tagged with each neighbour cell ID\n",
    "#these copies are the 'epsilon buffer' points that wil be sent to neighbouring partitions\n",
    "#these are marked is_buffer=True\n",
    "\n",
    "neighbour_df = (\n",
    "  gridded_partitioned_df\n",
    "  .withColumn(\"neighbour_ids\", neighbour_cells_udf(\"grid_row\", \"grid_col\"))\n",
    "  .withColumn(\"target_cell_id\", F.explode(\"neighbour_ids\"))\n",
    "  .drop(\"neighbour_ids\")\n",
    "  .withColumn(\"is_buffer\", F.lit(True))\n",
    "  #renaming the cell the point will be sent to\n",
    "  .withColumnRenamed(\"grid_cell_id\", \"home_cell_id\")\n",
    "  .withColumnRenamed(\"target_cell_id\", \"grid_cell_id\")\n",
    ")\n",
    "\n",
    "#original points\n",
    "original_df = gridded_partitioned_df.withColumn(\"is_buffer\", F.lit(False))\n",
    "\n",
    "#union; each partition now contains its own points + buffer points from neighbours\n",
    "buffered_df = (\n",
    "  original_df\n",
    "  .select(\"latitude\", \"longitude\", \"grid_cell_id\", \"is_buffer\")\n",
    "  .union(\n",
    "    neighbour_df.select(\"latitude\", \"longitude\", \"grid_cell_id\", \"is_buffer\")\n",
    "  )\n",
    "  .repartition(N_PARTITIONS, \"grid_cell_id\") #reshuffle so each cell gets its buffer\n",
    ")\n",
    "print(f\"Buffered DataFrame row count: {buffered_df.count():,}\")"
   ]
