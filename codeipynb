    "\n",
    "print(f\"5% subset loaded: {len(subset_5pct_pd):,} rows\")\n",
    "\n",
    "#deduplication: keep unique coordinate pairs \n",
    "unique_coords = subset_5pct_pd.drop_duplicates(subset=[\"latitude\", \"longitude\"]).copy()\n",
    "print(f\"Unique coordinate rows: {len(unique_coords):,}\")\n",
    "\n",
    "#extract coordinate features from unique set\n",
    "X_baseline = unique_coords[[\"latitude\", \"longitude\"]].values\n",
    "\n",
    "#run sequential DBSCAN \n",
    "t_start = time.time()\n",
    "\n",
    "baseline_dbscan = DBSCAN(\n",
