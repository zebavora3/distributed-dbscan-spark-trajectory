    "# author: Javeria\n",
    "# Experiment: Effect of number of partitions on runtime and clusters (5% subset)\n",
    "\n",
    "import matplotlib.pyplot as plt\n",
    "import time\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "subset_name = \"5%\"\n",
    "subset_path = \"subsets/5pct/\"\n",
    "partition_counts = [100, 200, 400, 800, 1600, 3200]\n",
    "\n",
    "# Load subset trajectory IDs\n",
    "subset_df = spark.read.parquet(DATA_PATH + subset_path)\n",
    "subset_ids = subset_df.select(\"trajectory_id\").distinct()\n",
    "\n",
    "# Base buffered DataFrame (without repartitioning)\n",
    "base_buffered = (\n",
    "    buffered_local\n",
    "    .join(F.broadcast(subset_ids), on=\"trajectory_id\", how=\"inner\")\n",
    "    .cache()\n",
    ")\n",
    "base_buffered.count()\n",
    "\n",
    "results_5 = []\n",
    "\n",
    "for n_part in partition_counts:\n",
    "    print(f\"\\n--- {subset_name} - {n_part} partitions ---\")\n",
    "    \n",
    "    repartitioned = base_buffered.repartition(n_part, \"grid_cell_id\")\n",
    "    repartitioned = repartitioned.checkpoint()\n",
    "    \n",
    "    t0 = time.time()\n",
    "    clustered = (\n",
    "        repartitioned\n",
    "        .groupBy(\"grid_cell_id\")\n",
    "        .applyInPandas(point_dbscan_per_cell, schema=LOCAL_RESULT_SCHEMA)\n",
    "        .cache()\n",
    "    )\n",
    "    total = clustered.count()\n",
    "    t1 = time.time()\n",
    "    \n",
    "    # Boundary merge\n",
    "    buffer_pts = clustered.filter((F.col(\"is_buffer\") == True) & (F.col(\"local_cluster\") != -1)) \\\n",
    "                          .select(\"latitude\", \"longitude\", F.col(\"local_cluster\").alias(\"buffer_cluster\"))\n",
    "    orig_pts = clustered.filter((F.col(\"is_buffer\") == False) & (F.col(\"local_cluster\") != -1)) \\\n",
    "                        .select(\"latitude\", \"longitude\", F.col(\"local_cluster\").alias(\"orig_cluster\"))\n",
    "    \n",
    "    pairs = buffer_pts.join(orig_pts, on=[\"latitude\", \"longitude\"], how=\"inner\") \\\n",
    "                      .filter(F.col(\"buffer_cluster\") != F.col(\"orig_cluster\")) \\\n",
    "                      .select(\"buffer_cluster\", \"orig_cluster\").distinct().toPandas()\n",
    "    \n",
    "    uf = UnionFind()\n",
    "    for _, row in pairs.iterrows():\n",
    "        uf.union(int(row[\"buffer_cluster\"]), int(row[\"orig_cluster\"]))\n",
    "    \n",
    "    all_ids = clustered.filter(F.col(\"local_cluster\") != -1).select(\"local_cluster\").distinct().toPandas()[\"local_cluster\"].tolist()\n",
    "    mapping = {cid: uf.find(cid) for cid in all_ids}\n",
    "    mapping_bcast = spark.sparkContext.broadcast(mapping)\n",
    "    \n",
    "    def remap(local_id):\n",
    "        if local_id is None or local_id == -1:\n",
    "            return -1\n",
    "        return mapping_bcast.value.get(int(local_id), int(local_id))\n",
