    "# author: Zeba\n",
    "# Global Approach — 5% Subset\n",
    "# Stage 1: Load subset, assign grid cells, apply Spark-level cap\n",
    "\n",
    "subset_5pct_global = spark.read.parquet(DATA_PATH + \"subsets/5pct/\")\n",
    "\n",
    "global_gridded_5 = (\n",
    "    subset_5pct_global\n",
    "    #remove exact duplicate GPS pings before gridding\n",
    "    .dropDuplicates([\"trajectory_id\", \"timestamp\", \"latitude\", \"longitude\"])\n",
    "    \n",
    "    #assign each point to a grid cell using spatial hashing\n",
    "    #grid_row and grid_col identify which cell the point falls in\n",
    "    .withColumn(\n",
    "        \"grid_row\",\n",
    "        F.floor((F.col(\"latitude\")  - F.lit(LAT_MIN)) / F.lit(CELL_SIZE)).cast(\"int\")\n",
    "    )\n",
    "    .withColumn(\n",
    "        \"grid_col\",\n",
    "        F.floor((F.col(\"longitude\") - F.lit(LON_MIN)) / F.lit(CELL_SIZE)).cast(\"int\")\n",
    "    )\n",
    "    \n",
    "    #drop any points that fall outside the Beijing bounding box\n",
    "    .filter(\n",
    "        (F.col(\"grid_row\") >= 0) & (F.col(\"grid_row\") < N_ROWS) &\n",
    "        (F.col(\"grid_col\") >= 0) & (F.col(\"grid_col\") < N_COLS)\n",
    "    )\n",
    "    \n",
    "    #single integer cell ID — used to group all points in the same cell\n",
    "    #onto the same worker via groupBy in Stage 2\n",
    "    .withColumn(\n",
    "        \"grid_cell_id\",\n",
    "        (F.col(\"grid_row\") * F.lit(N_COLS) + F.col(\"grid_col\")).cast(\"int\")\n",
    "    )\n",
    ")\n",
    "\n",
    "#Spark-level cap — keep at most 20,000 points per cell\n",
    "#BEFORE any data is sent to Python workers\n",
    "#this prevents executor OOM on the densest central Beijing cells\n",
