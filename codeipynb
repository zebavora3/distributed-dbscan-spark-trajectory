    "#load the 5% subset to driver as pandas \n",
    "subset_5pct_pd = (\n",
    "  spark.read.parquet(DATA_PATH + \"subsets/5pct/\")\n",
    "  .select(\"trajectory_id\", \"latitude\", \"longitude\")\n",
