    "#author: Javeria\n",
    "\n",
    "#at trajectory level 80/20\n",
    "\n",
    "TRAIN_FRACTION = 0.80\n",
    "TEST_FRACTION = 0.20\n",
    "\n",
    "#split trajectory IDs\n",
    "train_ids, test_ids = (\n",
    "  all_trajectory_ids\n",
    "  .randomSplit([TRAIN_FRACTION, TEST_FRACTION], seed=RANDOM_SEED)\n",
    ")\n",
    "\n",
    "train_df = clean_df.join(F.broadcast(train_ids), on=\"trajectory_id\", how=\"inner\")\n",
    "test_df = clean_df.join(F.broadcast(test_ids), on=\"trajectory_id\", how=\"inner\")\n",
    "\n",
    "print(f\"Train trajectories : {train_ids.count()}\")\n",
    "print(f\"Test trajectories : {test_ids.count()}\")\n",
    "print(f\"Train GPS points : {train_df.count():,}\")\n",
    "print(f\"Test GPS points : {test_df.count():,}\")\n",
    "\n",
    "#persist splits\n",
    "train_df.write.mode(\"overwrite\").parquet(DATA_PATH + \"splits/train/\")\n",
    "test_df.write.mode(\"overwrite\").parquet(DATA_PATH + \"splits/test/\")\n",
    "print(\"Splits saved.\")"
   ]
