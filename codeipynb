     "text": [
      "Subset 5pct: 651,466 rows saved to /mnt/2026-group9/subsets/5pct/\nSubset 10pct: 1,329,620 rows saved to /mnt/2026-group9/subsets_v2/10pct/\nSubset 25pct: 3,235,813 rows saved to /mnt/2026-group9/subsets_v2/25pct/\nFull dataset: 12,843,475 rows saved to /mnt/2026-group9/subsets_v2/full/\n"
     ]
    }
   ],
   "source": [
    "#author: Javeria\n",
    "\n",
    "SUBSET_FRACTIONS = {\"5pct\": 0.05, \"10pct\": 0.10, \"25pct\": 0.25}\n",
    "\n",
    "#get distinct trajectory IDs\n",
    "all_trajectory_ids = clean_df.select(\"trajectory_id\").distinct()\n",
    "\n",
    "subsets = {}\n",
    "\n",
    "for label, fraction in SUBSET_FRACTIONS.items():\n",
    "    # choose base directory: 'subsets/' for 5%, 'subsets_v2/' for others\n",
    "    if label == \"5pct\":\n",
    "        base_dir = \"subsets/\"\n",
    "    else:\n",
    "        base_dir = \"subsets_v2/\"\n",
    "    \n",
    "    #sample trajectory IDs at the given fraction\n",
    "    sampled_ids = all_trajectory_ids.sample(\n",
    "        withReplacement=False, \n",
    "        fraction=fraction, \n",
    "        seed=RANDOM_SEED\n",
    "    )\n",
    "\n",
    "    #filter full dataframe to only those trajectory IDs\n",
    "    subset_df = clean_df.join(\n",
    "        F.broadcast(sampled_ids), on=\"trajectory_id\", how=\"inner\"\n",
    "    )\n",
    "\n",
    "    #cache and persist to storage \n",
    "    subset_path = DATA_PATH + f\"{base_dir}{label}/\"\n",
    "    subset_df.write.mode(\"overwrite\").parquet(subset_path)\n",
    "    subsets[label] = subset_df\n",
    "    row_count = subset_df.count()\n",
    "    print(f\"Subset {label}: {row_count:,} rows saved to {subset_path}\")\n",
    "\n",
    "#save full cleaned dataset to subsets_v2/full/\n",
    "full_path = DATA_PATH + \"subsets_v2/full/\"\n",
    "clean_df.write.mode(\"overwrite\").parquet(full_path)\n",
    "print(f\"Full dataset: {clean_df.count():,} rows saved to {full_path}\")"
   ]
  },
