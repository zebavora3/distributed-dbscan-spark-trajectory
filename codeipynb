    "# author: Zeba\n",
    "#Global Approach — Schema and per-cell DBSCAN function\n",
    "#Reuses EPS, MIN_SAMPLES, CELL_SIZE, LAT_MIN/MAX, LON_MIN/MAX, N_ROWS, N_COLS\n",
    "#already defined above by Javeria\n",
    "\n",
    "#output schema for applyInPandas — Spark needs to know the exact\n",
    "#column names and types it will receive back from each Python worker\n",
    "\n",
    "from pyspark.sql.types import BooleanType\n",
    "\n",
    "GLOBAL_SCHEMA = StructType([\n",
    "    StructField(\"trajectory_id\",   IntegerType(), True),\n",
    "    StructField(\"timestamp\",       StringType(),  True),\n",
    "    StructField(\"latitude\",        DoubleType(),  True),\n",
    "    StructField(\"longitude\",       DoubleType(),  True),\n",
    "    StructField(\"grid_row\",        IntegerType(), True),\n",
    "    StructField(\"grid_col\",        IntegerType(), True),\n",
    "    StructField(\"grid_cell_id\",    IntegerType(), True),\n",
    "    StructField(\"global_label\",    LongType(),    True),\n",
    "    StructField(\"is_border_point\", BooleanType(), True),\n",
    "])\n",
    "\n",
    "#cap applied at Spark level BEFORE data reaches Python workers\n",
    "#this is intentional — applying it inside the function would load the full oversized partition into memory first, then trim it\n",
    "#which defeats the purpose and still causes OOM crashes\n",
    "\n",
    "MAX_POINTS_PER_CELL_GLOBAL = 20000\n",
    "\n",
    "#how many border points to sample per cluster per cell boundary\n",
    "#before the self-join in Stage 3\n",
    "#200 is enough to detect connectivity — we only need ONE pair to establish that two clusters should be merged\n",
    "MAX_BORDER_SAMPLE = 200\n",
    "\n",
    "def run_dbscan_per_cell_global(pdf: pd.DataFrame) -> pd.DataFrame:\n",
    "    #this function runs independently on each grid cell\n",
    "    #Spark calls it once per cell, on a separate Python worker\n",
    "    #workers do NOT communicate with each other here\n",
    "    #cross-partition connectivity is handled later in Stage 3\n",
    "    cols_out = [\n",
    "        \"trajectory_id\", \"timestamp\", \"latitude\", \"longitude\",\n",
    "        \"grid_row\", \"grid_col\", \"grid_cell_id\",\n",
    "        \"global_label\", \"is_border_point\"\n",
    "    ]\n",
    "\n",
    "    if pdf.empty:\n",
    "        return pd.DataFrame(columns=cols_out)\n",
    "\n",
    "    cell_id = int(pdf[\"grid_cell_id\"].iloc[0])\n",
    "    X = pdf[[\"latitude\", \"longitude\"]].to_numpy()\n",
    "    \n",
    "    \n",
    "    #standard sklearn DBSCAN — same parameters as sequential baseline\n",
    "    #ball_tree algorithm for efficient neighbourhood queries\n",
    "    labels = DBSCAN(\n",
    "        eps=EPS,\n",
    "        min_samples=MIN_SAMPLES,\n",
    "        metric=\"euclidean\",\n",
    "        algorithm=\"ball_tree\",\n",
    "        n_jobs=1\n",
    "    ).fit_predict(X)\n",
    "\n",
    "    pdf = pdf.copy()\n",
    "\n",
    "    #globally unique label encoding — prevents cross-worker collisions\n",
    "    pdf[\"global_label\"] = np.where(\n",
    "        labels == -1, -1,\n",
    "        cell_id * 1_000_000 + labels\n",
    "    ).astype(np.int64)\n",
    "\n",
    "    #border point detection — within EPS of any cell edge\n",
    "    cell_lat_min = LAT_MIN + int(pdf[\"grid_row\"].iloc[0]) * CELL_SIZE\n",
    "    cell_lat_max = cell_lat_min + CELL_SIZE\n",
    "    cell_lon_min = LON_MIN + int(pdf[\"grid_col\"].iloc[0]) * CELL_SIZE\n",
    "    cell_lon_max = cell_lon_min + CELL_SIZE\n",
    "\n",
    "    pdf[\"is_border_point\"] = (\n",
    "        ((pdf[\"latitude\"]  - cell_lat_min) < EPS) |\n",
    "        ((cell_lat_max - pdf[\"latitude\"])  < EPS) |\n",
    "        ((pdf[\"longitude\"] - cell_lon_min) < EPS) |\n",
    "        ((cell_lon_max - pdf[\"longitude\"]) < EPS)\n",
    "    )\n",
    "\n",
    "    pdf[\"timestamp\"] = pdf[\"timestamp\"].astype(str)\n",
    "\n",
    "    return pdf[cols_out]\n",
    "\n",
    "print(\"Global schema and per-cell DBSCAN function defined.\")\n",
    "print(f\"MAX_POINTS_PER_CELL_GLOBAL = {MAX_POINTS_PER_CELL_GLOBAL}\")\n",
