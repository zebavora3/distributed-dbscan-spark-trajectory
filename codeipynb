    "# Distance measure functions\n",
    "# author: Manoj\n",
    "\n",
    "def euclidean_centroid_distance(traj_a, traj_b):\n",
    "    #O(1) per pair. Compares mean position only.\n",
    "    centroid_a = traj_a.mean(axis=0)\n",
    "    centroid_b = traj_b.mean(axis=0)\n",
    "    return np.sqrt(np.sum((centroid_a - centroid_b) ** 2))\n",
    "\n",
    "\n",
    "def hausdorff_distance(traj_a, traj_b):\n",
    "    # O(m*n) per pair. Vectorised with NumPy to speed up the computation.\n",
    "    traj_a = np.array(traj_a)\n",
    "    traj_b = np.array(traj_b)\n",
    "    dists = np.sqrt(((traj_a[:, None] - traj_b[None, :]) ** 2).sum(axis=2))\n",
    "    return max(dists.min(axis=1).max(), dists.min(axis=0).max())\n",
    "\n",
    "\n",
    "def dtw_distance(traj_a, traj_b):\n",
    "    # O(m*n) time and memory. Full DP cost matrix.\n",
    "    m, n = len(traj_a), len(traj_b)\n",
    "    cost = np.full((m + 1, n + 1), np.inf)\n",
    "    cost[0, 0] = 0.0\n",
    "    for i in range(1, m + 1):\n",
    "        for j in range(1, n + 1):\n",
    "            d = np.sqrt(np.sum((traj_a[i-1] - traj_b[j-1]) ** 2))\n",
    "            cost[i, j] = d + min(cost[i-1, j], cost[i, j-1], cost[i-1, j-1])\n",
    "    return cost[m, n]\n",
    "\n",
    "\n",
    "DISTANCE_MEASURES = {\n",
    "    \"euclidean_centroid\": euclidean_centroid_distance,\n",
    "    \"hausdorff\": hausdorff_distance,\n",
    "    \"dtw\": dtw_distance,\n",
    "}"
   ]
