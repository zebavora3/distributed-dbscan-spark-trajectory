    "# Per-cell DBSCAN function \n",
    "# author: Manoj\n",
    "\n",
    "from sklearn.cluster import DBSCAN as SklearnDBSCAN\n",
    "# necessary types for schema definition\n",
    "from pyspark.sql.types import BooleanType, StructType, StructField, IntegerType, DoubleType, LongType  \n",
    "\n",
    "MAX_TRAJS_PER_CELL = 50      \n",
    "MAX_POINTS_PER_TRAJ = 30     \n",
    "\n",
    "DBSCAN_OUTPUT_SCHEMA = StructType([\n",
    "    StructField(\"trajectory_id\",  IntegerType(), True),\n",
    "    StructField(\"latitude\",       DoubleType(),  True),\n",
    "    StructField(\"longitude\",      DoubleType(),  True),\n",
    "    StructField(\"grid_cell_id\",   IntegerType(), True),\n",
    "    StructField(\"is_buffer\",      BooleanType(), True),\n",
    "    StructField(\"local_cluster\",  LongType(),    True),\n",
    "])\n",
    "\n",
    "active_measure = \"euclidean_centroid\"\n",
    "\n",
    "def trajectory_dbscan_per_cell(pdf: pd.DataFrame) -> pd.DataFrame:\n",
    "    cols_out = [\"trajectory_id\", \"latitude\", \"longitude\",\n",
    "                \"grid_cell_id\", \"is_buffer\", \"local_cluster\"]\n",
    "\n",
    "    if pdf.empty:\n",
    "        return pd.DataFrame(columns=cols_out)\n",
    "\n",
    "    cell_id = int(pdf[\"grid_cell_id\"].iloc[0])\n",
    "    \n",
    "    distance_fn = DISTANCE_MEASURES[active_measure] \n",
    "\n",
    "    # grouped GPS points into trajectories\n",
    "    traj_groups = {}\n",
    "    for tid, group in pdf.groupby(\"trajectory_id\"):\n",
    "        coords = group[[\"latitude\", \"longitude\"]].to_numpy()\n",
    "        if len(coords) >= 2:\n",
    "            if len(coords) > 30:\n",
    "                coords = coords[:30]\n",
    "            traj_groups[tid] = coords\n",
    "\n",
    "    if len(traj_groups) > 50:\n",
    "        keys = list(traj_groups.keys())[:50]\n",
    "        traj_groups = {k: traj_groups[k] for k in keys}\n",
    "\n",
    "    traj_ids = list(traj_groups.keys())\n",
    "    trajectories = list(traj_groups.values())\n",
    "    n_trajs = len(trajectories)\n",
    "\n",
    "    # Not enough trajectories for DBSCAN\n",
    "    if n_trajs < MIN_SAMPLES:\n",
    "        pdf = pdf.copy()\n",
    "        pdf[\"local_cluster\"] = np.int64(-1)\n",
    "        return pdf[cols_out]\n",
    "\n",
    "    # built the pairwise distance matrix manually\n",
    "    dist_matrix = np.zeros((n_trajs, n_trajs))\n",
    "    for i in range(n_trajs):\n",
    "        for j in range(i + 1, n_trajs):\n",
    "            d = distance_fn(trajectories[i], trajectories[j])\n",
    "            dist_matrix[i, j] = d\n",
    "            dist_matrix[j, i] = d\n",
    "\n",
    "    # Run DBSCAN on the precomputed distance matrix\n",
    "    traj_labels = SklearnDBSCAN(\n",
    "        eps=EPS,\n",
    "        min_samples=MIN_SAMPLES,\n",
    "        metric=\"precomputed\"\n",
    "    ).fit_predict(dist_matrix)\n",
    "\n",
    "    # Map: trajectory_id -> globally unique cluster label\n",
    "    traj_label_map = {}\n",
    "    for idx, tid in enumerate(traj_ids):\n",
    "        label = int(traj_labels[idx])\n",
    "        if label == -1:\n",
    "            traj_label_map[tid] = np.int64(-1)\n",
    "        else:\n",
    "            traj_label_map[tid] = np.int64(cell_id * 1_000_000 + label)\n",
    "\n",
    "    # Assign labels to every GPS point\n",
    "    pdf = pdf.copy()\n",
    "    pdf[\"local_cluster\"] = (\n",
    "        pdf[\"trajectory_id\"]\n",
    "        .map(traj_label_map)\n",
    "        .fillna(-1)\n",
    "        .astype(np.int64)\n",
    "    )\n",
    "\n",
    "    return pdf[cols_out]"
   ]
