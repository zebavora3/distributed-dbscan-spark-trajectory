    "#author: Javeria\n",
    "#Enhanced epsilon buffer: directional copying based on which edges\n",
    "#a point is near. Reduces data duplication vs copying to all 8 neighbours.\n",
    "#Grounded in RP-DBSCAN (Lee et al.) directional buffer approach.\n",
    "\n",
    "N_ROWS = math.ceil((LAT_MAX - LAT_MIN) / CELL_SIZE)\n",
    "N_COLS = math.ceil((LON_MAX - LON_MIN) / CELL_SIZE)\n",
    "\n",
    "original_df = (\n",
    "    gridded_df\n",
    "    .withColumn(\"is_buffer\", F.lit(False))\n",
    "    .select(\"trajectory_id\", \"timestamp\", \"latitude\", \"longitude\",\n",
    "            \"grid_cell_id\", \"grid_row\", \"grid_col\", \"is_buffer\")\n",
    ")\n",
    "\n",
    "#compute cell boundaries for each point\n",
    "boundary_df = (\n",
    "    gridded_df\n",
    "    .withColumn(\"cell_lat_min\", LAT_MIN + F.col(\"grid_row\") * CELL_SIZE)\n",
    "    .withColumn(\"cell_lat_max\", F.col(\"cell_lat_min\") + CELL_SIZE)\n",
    "    .withColumn(\"cell_lon_min\", LON_MIN + F.col(\"grid_col\") * CELL_SIZE)\n",
    "    .withColumn(\"cell_lon_max\", F.col(\"cell_lon_min\") + CELL_SIZE)\n",
    "    #Boolean flags for which edges this point is near\n",
    "    .withColumn(\"near_south\", (F.col(\"latitude\")  - F.col(\"cell_lat_min\")) < EPS)\n",
    "    .withColumn(\"near_north\", (F.col(\"cell_lat_max\") - F.col(\"latitude\"))  < EPS)\n",
    "    .withColumn(\"near_west\",  (F.col(\"longitude\") - F.col(\"cell_lon_min\")) < EPS)\n",
    "    .withColumn(\"near_east\",  (F.col(\"cell_lon_max\") - F.col(\"longitude\")) < EPS)\n",
    "    .filter(\n",
    "        F.col(\"near_south\") | F.col(\"near_north\") |\n",
    "        F.col(\"near_west\")  | F.col(\"near_east\")\n",
    "    )\n",
    ")\n",
    "\n",
    "#build target cell list based on which edges the point is near\n",
    "#only copy to cells that are actually relevant for that direction\n",
    "def get_directional_neighbours(grid_row, grid_col, near_south, near_north,\n",
    "                                near_west, near_east, n_cols, n_rows):\n",
    "    targets = set()\n",
    "    if near_south and grid_row > 0:\n",
    "        targets.add((grid_row - 1) * n_cols + grid_col)\n",
    "    if near_north and grid_row < n_rows - 1:\n",
    "        targets.add((grid_row + 1) * n_cols + grid_col)\n",
    "    if near_west and grid_col > 0:\n",
    "        targets.add(grid_row * n_cols + (grid_col - 1))\n",
    "    if near_east and grid_col < n_cols - 1:\n",
    "        targets.add(grid_row * n_cols + (grid_col + 1))\n",
    "    #corners: only if near both edges\n",
    "    if near_south and near_west and grid_row > 0 and grid_col > 0:\n",
    "        targets.add((grid_row - 1) * n_cols + (grid_col - 1))\n",
    "    if near_south and near_east and grid_row > 0 and grid_col < n_cols - 1:\n",
    "        targets.add((grid_row - 1) * n_cols + (grid_col + 1))\n",
    "    if near_north and near_west and grid_row < n_rows - 1 and grid_col > 0:\n",
    "        targets.add((grid_row + 1) * n_cols + (grid_col - 1))\n",
    "    if near_north and near_east and grid_row < n_rows - 1 and grid_col < n_cols - 1:\n",
    "        targets.add((grid_row + 1) * n_cols + (grid_col + 1))\n",
    "    return list(targets)\n",
    "\n",
    "directional_neighbours_udf = F.udf(\n",
    "    lambda r, c, s, n, w, e: get_directional_neighbours(r, c, s, n, w, e, N_COLS, N_ROWS),\n",
    "    ArrayType(IntegerType())\n",
    ")\n",
    "\n",
    "neighbour_buffer = (\n",
    "    boundary_df\n",
    "    .withColumn(\"target_ids\", directional_neighbours_udf(\n",
    "        \"grid_row\", \"grid_col\",\n",
    "        \"near_south\", \"near_north\", \"near_west\", \"near_east\"\n",
    "    ))\n",
    "    .withColumn(\"target_cell_id\", F.explode(\"target_ids\"))\n",
    "    .withColumn(\"is_buffer\", F.lit(True))\n",
    "    .withColumnRenamed(\"grid_cell_id\", \"home_cell_id\")\n",
    "    .withColumnRenamed(\"target_cell_id\", \"grid_cell_id\")\n",
    "    .select(\"trajectory_id\", \"timestamp\", \"latitude\", \"longitude\",\n",
    "            \"grid_cell_id\", \"is_buffer\")\n",
    ")\n",
    "\n",
    "buffered_local = (\n",
    "    original_df\n",
    "    .select(\"trajectory_id\", \"timestamp\", \"latitude\", \"longitude\",\n",
    "            \"grid_cell_id\", \"is_buffer\")\n",
    "    .union(neighbour_buffer)\n",
    "    .repartition(N_PARTITIONS, \"grid_cell_id\")\n",
    "    .cache()\n",
    ")\n",
    "\n",
    "total = buffered_local.count()\n",
    "n_buffer = buffered_local.filter(F.col(\"is_buffer\") == True).count()\n",
    "n_original = total - n_buffer\n",
    "print(f\"Total rows       : {total:,}\")\n",
    "print(f\"Original points  : {n_original:,}\")\n",
    "print(f\"Buffer points    : {n_buffer:,}\")\n",
    "print(f\"Duplication ratio: {total/n_original:.2f}x (was 9x before)\")"
   ]
