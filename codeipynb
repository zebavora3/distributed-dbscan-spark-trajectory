    "# author: Zeba\n",
    "# Global Approach — 5% Subset\n",
    "# Stage 4: Union-Find merge + broadcast join for final labels\n",
    "\n",
    "#at this point we have a list of (cluster_a, cluster_b) pairs that need to be merged — Union-Find resolves these into\n",
    "#canonical labels (each group of connected clusters gets one ID)\n",
    "\n",
    "#then we broadcast the mapping back to all workers\n",
    "#broadcast join is much faster than a UDF here —\n",
    "#the UDF approach took 546 seconds, broadcast join takes ~5 seconds\n",
    "\n",
    "t2_global_5 = time.time()\n",
    "\n",
    "#build union-find from all merge pairs found in Stage 3\n",
    "uf_5 = UnionFind()\n",
    "for _, row in boundary_pairs_global_5.iterrows():\n",
    "    uf_5.union(int(row[\"cluster_a\"]), int(row[\"cluster_b\"]))\n",
    "\n",
    "#get all unique cluster IDs from the partitioned data\n",
    "cluster_ids_5 = (\n",
    "    global_partitioned_5\n",
    "    .filter(F.col(\"global_label\") != -1)\n",
    "    .select(\"global_label\").distinct()\n",
    "    .toPandas()[\"global_label\"].tolist()\n",
    ")\n",
    "\n",
    "clusters_before_5 = len(cluster_ids_5)\n",
    "\n",
    "#map every local fragment label to its canonical global label\n",
    "mapping_pd_5 = pd.DataFrame({\n",
    "    \"global_label\" : cluster_ids_5,\n",
    "    \"final_cluster\": [uf_5.find(int(x)) for x in cluster_ids_5]\n",
    "})\n",
    "\n",
    "#convert mapping to Spark DataFrame and broadcast to all workers\n",
    "#broadcast join avoids sending the full dataset back to the driver\n",
    "mapping_spark_5 = spark.createDataFrame(mapping_pd_5)\n",
    "\n",
    "global_final_5 = (\n",
    "    global_partitioned_5\n",
    "    .join(F.broadcast(mapping_spark_5), on=\"global_label\", how=\"left\")\n",
    "    .withColumn(\n",
    "        \"final_cluster\",\n",
    "        F.when(F.col(\"global_label\") == -1, F.lit(-1))\n",
    "         .otherwise(F.col(\"final_cluster\"))\n",
    "    )\n",
    "    .cache()\n",
    ")\n",
    "\n",
    "total_final_5   = global_final_5.count()\n",
    "clusters_after_5 = global_final_5.filter(F.col(\"final_cluster\") != -1).select(\"final_cluster\").distinct().count()\n",
    "noise_final_5    = global_final_5.filter(F.col(\"final_cluster\") == -1).count()\n",
    "\n",
    "t_step4_global_5 = time.time() - t2_global_5\n",
    "t_total_global_5 = t_step2_global_5 + t_step3_global_5 + t_step4_global_5\n",
    "\n",
    "print(f\"5% Global — Stage 4 complete\")\n",
    "print(f\"  Clusters before merge : {clusters_before_5:,}\")\n",
    "print(f\"  Clusters after merge  : {clusters_after_5}\")\n",
    "print(f\"  Runtime               : {t_step4_global_5:.2f}s\")\n",
    "print(f\"\\n 5% Global Results \")\n",
    "print(f\"  Total runtime    : {t_total_global_5:.2f}s\")\n",
    "print(f\"    Stage 2        : {t_step2_global_5:.2f}s\")\n",
    "print(f\"    Stage 3        : {t_step3_global_5:.2f}s\")\n",
    "print(f\"    Stage 4        : {t_step4_global_5:.2f}s\")\n",
    "print(f\"  Total points     : {total_final_5:,} (100%)\")\n",
    "print(f\"  Final clusters   : {clusters_after_5}\")\n",
    "print(f\"  Noise points     : {noise_final_5:,} ({100*noise_final_5/total_final_5:.2f}%)\")\n",
    "\n",
    "#save final results to parquet for evaluation and comparison\n",
    "global_final_5.write.mode(\"overwrite\").parquet(DATA_PATH + \"results_v2/global_final_5pct/\")\n",
    "print(f\"\\nSaved to results_v2/global_final_5pct/\")"
