    "# author: Javeria\n",
    "# Experiment: Effect of n_jobs (CPU cores) on runtime and clusters (5% subset)\n",
    "\n",
    "from sklearn.cluster import DBSCAN as SkDBSCAN\n",
    "\n",
    "def point_dbscan_with_cores(pdf: pd.DataFrame, n_jobs: int) -> pd.DataFrame:\n",
    "    \"\"\"Same as point_dbscan_per_cell but with configurable n_jobs.\"\"\"\n",
    "    cols_out = [\"latitude\", \"longitude\", \"grid_cell_id\", \"is_buffer\", \"local_cluster\"]\n",
    "    if pdf.empty:\n",
    "        return pd.DataFrame(columns=cols_out)\n",
    "    cell_id = int(pdf[\"grid_cell_id\"].iloc[0])\n",
    "    if len(pdf) > SAFE_MAX_POINTS_PER_CELL:\n",
    "        pdf = pdf.sample(n=SAFE_MAX_POINTS_PER_CELL, random_state=RANDOM_SEED)\n",
    "    X = pdf[[\"latitude\", \"longitude\"]].to_numpy()\n",
    "    labels = SkDBSCAN(eps=EPS, min_samples=MIN_SAMPLES,\n",
    "                      metric=\"euclidean\", algorithm=\"ball_tree\",\n",
    "                      n_jobs=n_jobs).fit_predict(X)\n",
    "    pdf = pdf.copy()\n",
    "    pdf[\"local_cluster\"] = np.where(labels == -1, -1, cell_id * 1_000_000 + labels).astype(np.int64)\n",
    "    return pdf[cols_out]\n",
    "\n",
    "# Test different n_jobs values\n",
    "n_jobs_list = [1, 2, 4, 8]  # adjust based on your executor cores (max likely 4 or 8 on shared cluster)\n",
    "\n",
    "# Use 5% subset again\n",
    "subset_5pct = spark.read.parquet(DATA_PATH + \"subsets/5pct/\")\n",
    "subset_ids_5 = subset_5pct.select(\"trajectory_id\").distinct()\n",
    "base_buffered = (\n",
    "    buffered_local\n",
    "    .join(F.broadcast(subset_ids_5), on=\"trajectory_id\", how=\"inner\")\n",
    "    .repartition(N_PARTITIONS, \"grid_cell_id\")  # use original partition count\n",
    "    .cache()\n",
    ")\n",
    "base_buffered.count()\n",
    "\n",
    "results_cores = []\n",
    "\n",
    "for nj in n_jobs_list:\n",
    "    print(f\"\\n--- Testing n_jobs = {nj} ---\")\n",
    "    \n",
    "    # Create a UDF wrapper that captures nj\n",
    "    def make_udf(nj):\n",
    "        def udf(pdf):\n",
    "            return point_dbscan_with_cores(pdf, nj)\n",
    "        return udf\n",
    "    \n",
