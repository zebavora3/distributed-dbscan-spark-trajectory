    "  min_samples=MIN_SAMPLES, \n",
    "  metric=\"euclidean\",\n",
    "  algorithm=\"ball_tree\",\n",
    "  n_jobs=1 # single thread\n",
    ")\n",
    "baseline_labels = baseline_dbscan.fit_predict(X_baseline)  #labels for unique coordinates\n",
    "\n",
    "t_end = time.time()\n",
    "baseline_runtime = t_end - t_start \n",
    "\n",
    "#attach labels to the unique DataFrame \n",
