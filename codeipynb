     "text": [
      "Clean row count: 12,843,475\nroot\n |-- trajectory_id: integer (nullable = true)\n |-- longitude: double (nullable = true)\n |-- latitude: double (nullable = true)\n |-- timestamp: timestamp (nullable = true)\n\n+-------------+---------+--------+-------------------+\n|trajectory_id|longitude|latitude|          timestamp|\n+-------------+---------+--------+-------------------+\n|         6275|116.36838|39.90484|2008-02-02 13:30:44|\n|         6275|116.36838|39.90484|2008-02-02 13:30:45|\n|         6275|116.36838|39.90484|2008-02-02 13:30:46|\n|         6275|116.36838|39.90484|2008-02-02 13:30:47|\n|         6275|116.36838|39.90484|2008-02-02 13:30:48|\n+-------------+---------+--------+-------------------+\nonly showing top 5 rows\n\n"
     ]
    }
   ],
   "source": [
    "#author: Javeria\n",
    "\n",
    "clean_df = (\n",
    "    raw_df\n",
    "    .withColumn(\"timestamp\", F.to_timestamp(F.col(\"date_time\"), \"yyyy-MM-dd HH:mm:ss\"))\n",
    "    .drop(\"date_time\", \"source_file\")\n",
    "    .withColumnRenamed(\"taxi_id\", \"trajectory_id\")\n",
    "    .dropna(subset=[\"latitude\", \"longitude\", \"timestamp\"])\n",
    "    .filter(\n",
    "        (F.col(\"latitude\").between(39.83, 40.12)) &\n",
    "        (F.col(\"longitude\").between(116.25, 116.64))\n",
    "    )\n",
    ")\n",
    "\n",
    "print(f\"Clean row count: {clean_df.count():,}\")\n",
    "clean_df.printSchema()\n",
    "clean_df.show(5)"
   ]
