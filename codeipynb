    "SAFE_MAX_POINTS_PER_CELL = 10000   #subsample if raw points exceed this\n",
    "\n",
    "def point_dbscan_per_cell(pdf: pd.DataFrame) -> pd.DataFrame:\n",
    "    cols_out = [\"latitude\", \"longitude\", \"grid_cell_id\", \"is_buffer\", \"local_cluster\"]\n",
    "\n",
    "    if pdf.empty:\n",
    "        return pd.DataFrame(columns=cols_out)\n",
    "\n",
    "    cell_id = int(pdf[\"grid_cell_id\"].iloc[0])\n",
    "\n",
    "    #subsample if cell is too large\n",
    "    if len(pdf) > SAFE_MAX_POINTS_PER_CELL:\n",
    "        pdf = pdf.sample(n=SAFE_MAX_POINTS_PER_CELL, random_state=RANDOM_SEED)\n",
    "\n",
    "    X = pdf[[\"latitude\", \"longitude\"]].to_numpy(dtype=np.float32)\n",
    "    labels = DBSCAN(eps=EPS, min_samples=MIN_SAMPLES,\n",
    "                    metric=\"euclidean\", algorithm=\"ball_tree\",\n",
    "                    n_jobs=1).fit_predict(X)\n",
    "\n",
    "    pdf = pdf.copy()\n",
    "    pdf[\"local_cluster\"] = np.where(\n",
    "        labels == -1, -1, cell_id * 1_000_000 + labels\n",
    "    ).astype(np.int64)\n",
    "    return pdf[cols_out]"
   ]
