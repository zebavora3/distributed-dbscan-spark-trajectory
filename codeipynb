    "def assign_grid_cell(df, cell_size=CELL_SIZE):\n",
    "  #assign each point to a grid cell \n",
    "  #cell size must be >2*epsilon for proper boundary buffer handling \n",
    "  n_cols = math.ceil((LON_MAX - LON_MIN) / cell_size)\n",
