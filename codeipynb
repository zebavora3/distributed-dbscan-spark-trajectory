    "FINAL_OUTPUT_SCHEMA = StructType([\n",
    "    StructField(\"trajectory_id\",  IntegerType(), True),\n",
    "    StructField(\"timestamp\",      StringType(),  True),\n",
    "    StructField(\"latitude\",       DoubleType(),  True),\n",
    "    StructField(\"longitude\",      DoubleType(),  True),\n",
    "    StructField(\"grid_cell_id\",   IntegerType(), True),\n",
    "    StructField(\"is_buffer\",      BooleanType(), True),\n",
    "    StructField(\"local_cluster\",  LongType(),    True),\n",
    "])\n",
    "\n",
    "\n",
    "def final_dbscan_per_cell(pdf: pd.DataFrame) -> pd.DataFrame:\n",
    "\n",
    "    cols_out = [\"trajectory_id\", \"timestamp\", \"latitude\", \"longitude\", \n",
    "                \"grid_cell_id\", \"is_buffer\", \"local_cluster\"]\n",
    "\n",
    "    if pdf.empty:\n",
    "        return pd.DataFrame(columns=cols_out)\n",
    "\n",
    "    cell_id = int(pdf[\"grid_cell_id\"].iloc[0])\n",
    "\n",
    "    centroids = (\n",
    "        pdf.groupby(\"trajectory_id\")[[\"latitude\", \"longitude\"]]\n",
    "        .mean()\n",
    "        .reset_index()\n",
    "    )\n",
    "\n",
    "    if len(centroids) < MIN_SAMPLES:\n",
    "        pdf = pdf.copy()\n",
    "        pdf[\"local_cluster\"] = np.int64(-1)\n",
    "        pdf[\"timestamp\"] = pdf[\"timestamp\"].astype(str)\n",
    "        return pdf[cols_out]\n",
    "\n",
    "    X = centroids[[\"latitude\", \"longitude\"]].to_numpy()\n",
    "\n",
    "    labels = SklearnDBSCAN(\n",
    "        eps=CHOSEN_EPS,\n",
    "        min_samples=MIN_SAMPLES,\n",
    "        metric=\"euclidean\",\n",
    "        algorithm=\"ball_tree\",\n",
    "        n_jobs=1\n",
    "    ).fit_predict(X)\n",
    "\n",
    "    centroids[\"local_cluster\"] = np.where(\n",
    "        labels == -1,\n",
    "        -1,\n",
    "        cell_id * 1_000_000 + labels\n",
    "    ).astype(np.int64)\n",
    "\n",
    "    label_map = dict(zip(centroids[\"trajectory_id\"], centroids[\"local_cluster\"]))\n",
    "\n",
    "    pdf = pdf.copy()\n",
    "    pdf[\"local_cluster\"] = (\n",
    "        pdf[\"trajectory_id\"]\n",
    "        .map(label_map)\n",
    "        .fillna(-1)\n",
    "        .astype(np.int64)\n",
    "    )\n",
    "\n",
    "    pdf[\"timestamp\"] = pdf[\"timestamp\"].astype(str)\n",
    "\n",
    "    return pdf[cols_out]\n",
    "\n",
    "\n",
    "t0 = time.time()\n",
    "\n",
    "rq3_clustered_df = (\n",
    "    buffered_with_tid\n",
    "    .groupBy(\"grid_cell_id\")\n",
    "    .applyInPandas(final_dbscan_per_cell, schema=FINAL_OUTPUT_SCHEMA)\n",
    "    .cache()\n",
    ")\n",
    "\n",
    "total_points = rq3_clustered_df.count()\n",
    "t1 = time.time()\n",
    "\n",
    "n_clustered = rq3_clustered_df.filter(F.col(\"local_cluster\") != -1).count()\n",
    "n_noise = rq3_clustered_df.filter(F.col(\"local_cluster\") == -1).count()\n",
    "n_clusters = (\n",
    "    rq3_clustered_df\n",
    "    .filter(F.col(\"local_cluster\") != -1)\n",
    "    .select(\"local_cluster\").distinct().count()\n",
    ")\n",
    "\n",
    "print(\"\\nRQ3 Final — Trajectory-centroid DBSCAN with {} (no caps)\".format(CHOSEN_MEASURE))\n",
    "print(\"  Runtime         : {:.2f}s\".format(t1 - t0))\n",
    "print(\"  Total points    : {:,}\".format(total_points))\n",
    "print(\"  Clustered points: {:,}\".format(n_clustered))\n",
    "print(\"  Noise points    : {:,}\".format(n_noise))\n",
