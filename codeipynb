    "#author: Javeria\n",
    "#Boundary merge for 100% subset\n",
    "\n",
    "from pyspark.sql.types import LongType\n",
    "\n",
    "t0_merge_full = time.time()  \n",
    "\n",
    "buffer_clustered_full = (\n",
    "    local_clustered_full\n",
    "    .filter((F.col(\"is_buffer\") == True) & (F.col(\"local_cluster\") != -1))\n",
    "    .select(\"latitude\", \"longitude\",\n",
    "            F.col(\"local_cluster\").alias(\"buffer_cluster\"))\n",
    ")\n",
    "\n",
    "original_clustered_full = (\n",
    "    local_clustered_full\n",
    "    .filter((F.col(\"is_buffer\") == False) & (F.col(\"local_cluster\") != -1))\n",
    "    .select(\"latitude\", \"longitude\",\n",
    "            F.col(\"local_cluster\").alias(\"orig_cluster\"))\n",
    ")\n",
    "\n",
    "boundary_pairs_full = (\n",
    "    buffer_clustered_full\n",
    "    .join(original_clustered_full, on=[\"latitude\", \"longitude\"], how=\"inner\")\n",
    "    .filter(F.col(\"buffer_cluster\") != F.col(\"orig_cluster\"))\n",
    "    .select(\"buffer_cluster\", \"orig_cluster\")\n",
    "    .distinct()\n",
    "    .toPandas()\n",
    ")\n",
    "\n",
    "print(f\"Boundary merge pairs (100%): {len(boundary_pairs_full)}\")\n",
    "\n",
    "class UnionFind:\n",
    "    def __init__(self):\n",
    "        self.parent = {}\n",
    "    def find(self, x):\n",
    "        self.parent.setdefault(x, x)\n",
    "        if self.parent[x] != x:\n",
    "            self.parent[x] = self.find(self.parent[x])\n",
    "        return self.parent[x]\n",
    "    def union(self, x, y):\n",
    "        rx, ry = self.find(x), self.find(y)\n",
    "        if rx != ry:\n",
    "            self.parent[ry] = rx\n",
    "\n",
    "uf_full = UnionFind()\n",
    "for _, row in boundary_pairs_full.iterrows():\n",
    "    uf_full.union(int(row[\"buffer_cluster\"]), int(row[\"orig_cluster\"]))\n",
    "\n",
    "all_ids_full = (\n",
    "    local_clustered_full.filter(F.col(\"local_cluster\") != -1)\n",
    "    .select(\"local_cluster\").distinct()\n",
    "    .toPandas()[\"local_cluster\"].tolist()\n",
    ")\n",
    "\n",
    "mapping_full = {cid: uf_full.find(cid) for cid in all_ids_full}\n",
    "mapping_broadcast_full = spark.sparkContext.broadcast(mapping_full)\n",
    "\n",
    "@F.udf(returnType=LongType())\n",
    "def remap_cluster_full(local_id):\n",
    "    if local_id is None or local_id == -1:\n",
    "        return -1\n",
    "    return mapping_broadcast_full.value.get(int(local_id), int(local_id))\n",
    "\n",
    "local_final_full = (\n",
    "    local_clustered_full\n",
    "    .filter(F.col(\"is_buffer\") == False)\n",
    "    .withColumn(\"final_cluster\", remap_cluster_full(F.col(\"local_cluster\")))\n",
    "    .select(\"latitude\", \"longitude\", \"grid_cell_id\", \"final_cluster\")\n",
    "    .cache()\n",
    ")\n",
    "\n",
    "total_ffull       = local_final_full.count()\n",
    "t1_merge_full     = time.time()    \n",
    "t_merge_full      = t1_merge_full - t0_merge_full  \n",
    "t_total_full      = t_dbscan_full + t_merge_full   \n",
    "\n",
    "n_clustered_ffull = local_final_full.filter(F.col(\"final_cluster\") != -1).count()\n",
    "n_noise_ffull     = total_ffull - n_clustered_ffull\n",
    "n_clusters_ffull  = local_final_full.filter(F.col(\"final_cluster\") != -1) \\\n",
    "                                     .select(\"final_cluster\").distinct().count()\n",
    "\n",
    "print(f\"\\n=== 100% Local Approach After Boundary Merge ===\")\n",
    "print(f\"  Runtime (DBSCAN)         : {t_dbscan_full:.2f}s\")   \n",
    "print(f\"  Runtime (boundary merge) : {t_merge_full:.2f}s\")    \n",
    "print(f\"  Runtime (total)          : {t_total_full:.2f}s\")    \n",
    "print(f\"  Total points  : {total_ffull:,}\")\n",
    "print(f\"  Clustered     : {n_clustered_ffull:,} ({n_clustered_ffull/total_ffull*100:.2f}%)\")\n",
    "print(f\"  Noise         : {n_noise_ffull:,} ({n_noise_ffull/total_ffull*100:.2f}%)\")\n",
