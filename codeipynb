    "                        .withColumn(\"final_cluster\", remap_udf(F.col(\"local_cluster\"))) \\\n",
    "                        .select(\"final_cluster\")\n",
    "    \n",
    "    n_clusters = final_df.filter(F.col(\"final_cluster\") != -1).select(\"final_cluster\").distinct().count()\n",
