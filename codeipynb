    "# author: Zeba\n",
    "# Visualisation 1: Runtime breakdown per subset\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "fig.patch.set_facecolor(\"white\")\n",
    "\n",
    "subsets  = global_results_summary[\"subset\"].tolist()\n",
    "t_step2  = global_results_summary[\"stage2_runtime\"].tolist()\n",
    "t_step3  = global_results_summary[\"stage3_runtime\"].tolist()\n",
    "t_step4  = global_results_summary[\"stage4_runtime\"].tolist()\n",
    "runtimes = global_results_summary[\"total_runtime\"].tolist()\n",
    "\n",
    "# LEFT: stacked bar — step breakdown\n",
    "x = range(len(subsets))\n",
    "axes[0].bar(subsets, t_step2, label=\"Stage 2: Per-cell DBSCAN\",\n",
    "            color=\"#EF5350\", edgecolor=\"white\", linewidth=1.5)\n",
    "axes[0].bar(subsets, t_step3, bottom=t_step2,\n",
    "            label=\"Stage 3: Border comparison\",\n",
    "            color=\"#FF9800\", edgecolor=\"white\", linewidth=1.5)\n",
    "bottom = [a + b for a, b in zip(t_step2, t_step3)]\n",
    "axes[0].bar(subsets, t_step4, bottom=bottom,\n",
    "            label=\"Stage 4: Union-Find merge\",\n",
    "            color=\"#66BB6A\", edgecolor=\"white\", linewidth=1.5)\n",
    "\n",
    "for i, total in enumerate(runtimes):\n",
    "    axes[0].text(i, total + 2, f\"{total:.0f}s\",\n",
    "                 ha=\"center\", fontsize=10, fontweight=\"bold\")\n",
    "\n",
    "axes[0].set_xlabel(\"Dataset Subset\", fontsize=11)\n",
    "axes[0].set_ylabel(\"Runtime (seconds)\", fontsize=11)\n",
    "axes[0].set_title(\"Runtime Breakdown by Stage\",\n",
    "                   fontsize=12, fontweight=\"bold\")\n",
    "axes[0].legend(fontsize=9)\n",
    "axes[0].spines[\"top\"].set_visible(False)\n",
    "axes[0].spines[\"right\"].set_visible(False)\n",
    "axes[0].grid(axis=\"y\", alpha=0.3)\n",
    "\n",
    "# RIGHT: Stage 2 % of total\n",
    "pct_step2 = [100*s2/t for s2, t in zip(t_step2, runtimes)]\n",
    "pct_step3 = [100*s3/t for s3, t in zip(t_step3, runtimes)]\n",
    "pct_step4 = [100*s4/t for s4, t in zip(t_step4, runtimes)]\n",
    "\n",
    "axes[1].bar(subsets, pct_step2, label=\"Stage 2\",\n",
    "            color=\"#EF5350\", edgecolor=\"white\", linewidth=1.5)\n",
    "axes[1].bar(subsets, pct_step3, bottom=pct_step2,\n",
    "            label=\"Stage 3\", color=\"#FF9800\",\n",
    "            edgecolor=\"white\", linewidth=1.5)\n",
