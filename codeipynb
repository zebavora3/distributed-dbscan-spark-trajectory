    "# author: Zeba\n",
    "# Visualisation 4: Local vs Global comparison\n",
    "# Local results from Javeria's final table\n",
    "# median runtimes used\n",
    "\n",
    "local_runtimes  = [38.36, 64.77, 35.31, 45.53]\n",
    "local_clusters  = [23, 13, 11, 3]\n",
    "global_runtimes = [106.86, 148.09, 218.82, 283.38]\n",
    "global_clusters = [23, 19, 11, 5]\n",
    "subsets_common  = [\"5%\", \"10%\", \"25%\", \"100%\"]\n",
    "\n",
    "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
    "fig.patch.set_facecolor(\"white\")\n",
    "\n",
    "# LEFT: runtime comparison\n",
    "axes[0].plot(subsets_common, local_runtimes, marker=\"o\",\n",
    "              color=\"#42A5F5\", linewidth=2.5, markersize=10,\n",
    "              label=\"Local approach\")\n",
    "axes[0].plot(subsets_common, global_runtimes, marker=\"s\",\n",
    "              color=\"#EF5350\", linewidth=2.5, markersize=10,\n",
    "              linestyle=\"--\", label=\"Global approach\")\n",
