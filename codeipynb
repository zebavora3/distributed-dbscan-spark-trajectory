    "# author: Zeba\n",
    "# Global Approach — 5% Subset\n",
    "# Stage 3: Distributed border-point comparison\n",
    "\n",
    "#the non-trivial distributed step that makes this \"global\" instead of just independent per-cell DBSCAN\n",
    "#the problem: cell A thinks cluster 5000001 ends at its edge\n",
    "#             cell B thinks cluster 6000001 starts at its edge\n",
    "#             but they are actually the same physical cluster\n",
    "#\n",
    "#the solution: take border points from ALL cells and self-join\n",
    "#              if a point from cell A is within EPS of a point\n",
    "#              from neighbouring cell B, their clusters should merge\n",
    "#\n",
    "#optimisation: we sample 200 border points per cluster per cell.\n",
    "#              instead of joining all ~460k border points,\n",
    "#              we only need ONE connection to detect a merge.\n",
    "#              so sampling preserves correctness while reducing the join from millions of rows to tens of thousands\n",
    "\n",
    "border_df_5 = (\n",
    "    global_partitioned_5\n",
    "    .filter(\n",
    "        (F.col(\"is_border_point\") == True) &\n",
    "        (F.col(\"global_label\") != -1)\n",
    "    )\n",
    "    .cache()\n",
    ")\n",
    "\n",
    "w_border_5 = Window.partitionBy(\"global_label\", \"grid_cell_id\").orderBy(F.rand(seed=RANDOM_SEED))\n",
    "\n",
    "border_sampled_5 = (\n",
    "    border_df_5\n",
    "    .withColumn(\"rn\", F.row_number().over(w_border_5))\n",
    "    .filter(F.col(\"rn\") <= MAX_BORDER_SAMPLE)\n",
    "    .drop(\"rn\")\n",
    "    .cache()\n",
    ")\n",
    "\n",
    "n_border_sampled_5 = border_sampled_5.count()\n",
    "\n",
    "t1_global_5 = time.time()\n",
    "\n",
    "#self-join: compare every border point against every other border point\n",
    "#in neighbouring cells (grid_row and grid_col within 1 of each other)\n",
    "#then keep only pairs that are within EPS Euclidean distance\n",
    "a5 = border_sampled_5.alias(\"a\")\n",
    "b5 = border_sampled_5.alias(\"b\")\n",
    "\n",
    "boundary_pairs_global_5 = (\n",
    "    a5.join(b5,\n",
    "        on=(\n",
    "        #only compare points in adjacent cells\n",
    "            (F.abs(F.col(\"a.grid_row\") - F.col(\"b.grid_row\")) <= 1) &\n",
    "            (F.abs(F.col(\"a.grid_col\") - F.col(\"b.grid_col\")) <= 1)\n",
    "        ),\n",
    "        how=\"inner\"\n",
    "    )\n",
    "    #only interested in pairs from DIFFERENT clusters\n",
    "    .filter(F.col(\"a.global_label\") != F.col(\"b.global_label\"))\n",
    "    #check actual Euclidean distance — must be within EPS\n",
    "    .filter(\n",
    "        F.sqrt(\n",
    "            (F.col(\"a.latitude\")  - F.col(\"b.latitude\"))  ** 2 +\n",
    "            (F.col(\"a.longitude\") - F.col(\"b.longitude\")) ** 2\n",
    "        ) <= EPS\n",
    "    )\n",
    "    #store as (smaller_id, larger_id) to avoid duplicates\n",
    "    .select(\n",
    "        F.least(F.col(\"a.global_label\"), F.col(\"b.global_label\")).alias(\"cluster_a\"),\n",
    "        F.greatest(F.col(\"a.global_label\"), F.col(\"b.global_label\")).alias(\"cluster_b\")\n",
    "    )\n",
    "    .distinct()\n",
    "    .toPandas() #collect merge pairs to driver for Union-Find\n",
    ")\n",
    "\n",
    "t_step3_global_5 = time.time() - t1_global_5\n",
    "\n",
    "print(f\"5% Global — Stage 3 complete\")\n",
    "print(f\"  Border points sampled : {n_border_sampled_5:,}\")\n",
    "print(f\"  Merge pairs found     : {len(boundary_pairs_global_5):,}\")\n",
    "print(f\"  Runtime               : {t_step3_global_5:.2f}s\")"
   ]
